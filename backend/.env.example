# ════ BadCourt Backend Environment Variables ════

PORT=3000
NODE_ENV=development

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# LINE Developer Configuration
LINE_CHANNEL_SECRET=your-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token

# Admin LINE User IDs (comma-separated)
ADMIN_LINE_USER_IDS=userId1,userId2,userId3

# Slip Storage Bucket
SLIP_STORAGE_BUCKET=badcourt-slips

# Timezone (for cron jobs)
TZ=Asia/Bangkok

# PromptPay for QR generation
PROMPTPAY_NUMBER=0812345678
